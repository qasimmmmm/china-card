# ─────────────────────────────────────────────────────────────
# China Arrival Card — environment variables
# Copy to ".env.local" for local dev. Set the same keys in Vercel.
# Every value below is OPTIONAL — the app runs with sensible
# defaults so you can preview immediately.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO/canonical/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://china.ivisaportal.com

# Public brand / contact details shown in the UI.
NEXT_PUBLIC_SUPPORT_EMAIL=support@ivisaportal.com
NEXT_PUBLIC_COMPANY_NAME=iVisa Portal

# ── Order storage ────────────────────────────────────────────
# Storage driver: "file" (local dev) | "memory" | "postgres"
ORDER_STORE_DRIVER=file
# When ORDER_STORE_DRIVER=postgres, provide a connection string.
# Works with Vercel Postgres, Neon, Supabase, etc.
DATABASE_URL=

# ── Operator / automation worker ─────────────────────────────
# Shared secret protecting the operator API + worker pull endpoint.
OPERATOR_API_KEY=change-me-to-a-long-random-string
# Official China Customs health-declaration / fingertip service URL
# the worker should open. Leave blank to use the documented default.
OFFICIAL_PORTAL_URL=
# Run the worker headless (true) or headed for manual CAPTCHA/review (false).
WORKER_HEADLESS=false

# ── Live CAPTCHA-relay filing service (customer solves the CAPTCHA) ──
# URL of the running filing service (worker/filing-service.js). Leave BLANK to
# disable live filing — the site then falls back to assisted (staff) filing.
FILING_SERVICE_URL=
# Shared secret between the site and the filing service.
FILING_SERVICE_KEY=dev-filing-key

# ── Email delivery (Resend) — sends the customer their confirmation ──
# Unset = emails are skipped (logged only). Set to actually deliver mail.
RESEND_API_KEY=
# Must be a verified sender/domain in your Resend account.
EMAIL_FROM=China Arrival Card <no-reply@china.ivisaportal.com>
# EMAIL_REPLY_TO=support@ivisaportal.com

# ── Filing against the REAL NIA portal (worker, official mode) ──
# WORKER_PORTAL_MODE=official
# OFFICIAL_PORTAL_URL=https://s.nia.gov.cn/ArrivalCardFillingPC/
# Map the real form without editing code — copy selectors.official.example.json
# to worker/selectors.official.json and fill in the real selectors. Or override
# individual selectors here:
# WORKER_SELECTORS_FILE=
# WORKER_SUBMIT_HINTS=提交申报|确认提交|Submit
# WORKER_CONFIRM_SELECTOR=
# WORKER_CAPTCHA_IMAGE=
# WORKER_CAPTCHA_INPUT=
# WORKER_CAPTCHA_ERROR=

# ── Payments (optional — wire up before going live) ──────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Analytics (optional) ─────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GADS_CONVERSION_ID=
