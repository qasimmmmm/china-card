{
  "name": "china-arrival-card-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Operator-run automation that maps a customer's submitted application into the official NIA China Arrival Card form for human review and submission.",
  "engines": { "node": ">=18.18.0" },
  "scripts": {
    "serve": "node filing-service.js",
    "start": "node index.js --watch",
    "auto": "node index.js --auto",
    "watch": "node index.js --watch",
    "review": "node index.js --review",
    "queue": "node index.js --list",
    "dry-run": "node index.js --dry-run",
    "install-browser": "playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.49.1"
  }
}
